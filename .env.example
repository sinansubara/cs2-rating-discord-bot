# ─────────────────────────────────────────────────────────────────────────────
# CS2 Rating Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Discord Bot Token
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# FACEIT API Key (server-side key, not client key)
# Create one at https://developers.faceit.com → Apps → New App → Server-side API key
FACEIT_API_KEY=your_faceit_api_key_here

# Optional: Discord Guild (server) ID for instant command sync during development.
# Leave blank for global sync (takes ~1 hour to propagate).
# Right-click your server in Discord → Copy Server ID (requires Developer Mode).
GUILD_ID=
